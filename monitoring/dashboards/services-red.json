{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "datasource", "uid": "grafana"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-service RED metrics (Rate, Errors, Duration) for every Banka-3 backend service. Templated by service.",
  "editable": true,
  "graphTooltip": 1,
  "tags": ["banka", "red"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "All", "value": "$__all"},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(up{job=~\"gateway|user|bank|trading|exchange|notification|scheduler\"}, job)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "options": [],
        "query": {"query": "label_values(up{job=~\"gateway|user|bank|trading|exchange|notification|scheduler\"}, job)", "refId": "StandardVariableQuery"},
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {"selected": false, "text": "5m", "value": "5m"},
        "hide": 0,
        "name": "rate_window",
        "options": [
          {"selected": false, "text": "1m", "value": "1m"},
          {"selected": true,  "text": "5m", "value": "5m"},
          {"selected": false, "text": "15m", "value": "15m"},
          {"selected": false, "text": "1h", "value": "1h"}
        ],
        "query": "1m,5m,15m,1h",
        "skipUrlSync": false,
        "type": "custom"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Health",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Replicas up",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "orange", "value": 1},
            {"color": "green", "value": 2}
          ]},
          "unit": "none"
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "none", "textMode": "auto"},
      "targets": [
        {"expr": "sum(up{job=~\"$service\"})", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Pod restarts (1h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 4, "y": 1},
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "orange", "value": 1},
            {"color": "red", "value": 3}
          ]},
          "unit": "none"
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "none", "textMode": "auto"},
      "targets": [
        {"expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"raf-banka\",container=~\"$service\"}[1h]))", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Error rate (gRPC)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 8, "y": 1},
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "orange", "value": 1},
            {"color": "red", "value": 5}
          ]},
          "unit": "percent"
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "none", "textMode": "auto"},
      "targets": [
        {"expr": "100 * sum(rate(rpc_server_duration_milliseconds_count{job=~\"$service\",rpc_grpc_status_code!=\"0\"}[$rate_window])) / clamp_min(sum(rate(rpc_server_duration_milliseconds_count{job=~\"$service\"}[$rate_window])), 1)", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "gRPC p95 latency",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 12, "y": 1},
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "orange", "value": 100},
            {"color": "red", "value": 500}
          ]},
          "unit": "ms"
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "area", "textMode": "auto"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(rpc_server_duration_milliseconds_bucket{job=~\"$service\"}[$rate_window])))", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Memory (max pod)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 16, "y": 1},
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "orange", "value": 268435456},
            {"color": "red", "value": 536870912}
          ]},
          "unit": "bytes"
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area", "textMode": "auto"},
      "targets": [
        {"expr": "max(container_memory_working_set_bytes{namespace=\"raf-banka\",container=~\"$service\"})", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "CPU (sum)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 20, "y": 1},
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "orange", "value": 0.5},
            {"color": "red", "value": 1.0}
          ]},
          "unit": "none",
          "decimals": 2
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area", "textMode": "auto"},
      "targets": [
        {"expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"raf-banka\",container=~\"$service\"}[$rate_window]))", "refId": "A"}
      ]
    },

    {
      "type": "row",
      "title": "Rate",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6},
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Throughput — gRPC requests/sec by service",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 7},
      "id": 10,
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineInterpolation": "smooth", "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull","max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "sum by (job) (rate(rpc_server_duration_milliseconds_count{job=~\"$service\"}[$rate_window]))", "legendFormat": "{{job}}", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Throughput — HTTP requests/sec (gateway only)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 7},
      "id": 11,
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineInterpolation": "smooth", "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull","max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "sum by (job) (rate(http_server_request_duration_seconds_count{job=~\"$service\"}[$rate_window]))", "legendFormat": "{{job}}", "refId": "A"}
      ]
    },

    {
      "type": "row",
      "title": "Errors",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15},
      "id": 102,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "gRPC errors/sec by status code",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 20,
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineInterpolation": "smooth", "fillOpacity": 25, "stacking": {"mode": "normal"}}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull","max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "sum by (job, rpc_grpc_status_code) (rate(rpc_server_duration_milliseconds_count{job=~\"$service\",rpc_grpc_status_code!=\"0\"}[$rate_window]))", "legendFormat": "{{job}} code={{rpc_grpc_status_code}}", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "gRPC error ratio (non-OK / total)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 21,
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "min": 0, "custom": {"lineInterpolation": "smooth", "fillOpacity": 15}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull","max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "sum by (job) (rate(rpc_server_duration_milliseconds_count{job=~\"$service\",rpc_grpc_status_code!=\"0\"}[$rate_window])) / clamp_min(sum by (job) (rate(rpc_server_duration_milliseconds_count{job=~\"$service\"}[$rate_window])), 0.001)", "legendFormat": "{{job}}", "refId": "A"}
      ]
    },

    {
      "type": "row",
      "title": "Duration",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "id": 103,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "gRPC latency p50 / p95 / p99 per service",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 25},
      "id": 30,
      "fieldConfig": {"defaults": {"unit": "ms", "custom": {"lineInterpolation": "smooth", "fillOpacity": 5}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull","max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le, job) (rate(rpc_server_duration_milliseconds_bucket{job=~\"$service\"}[$rate_window])))", "legendFormat": "p50 {{job}}", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le, job) (rate(rpc_server_duration_milliseconds_bucket{job=~\"$service\"}[$rate_window])))", "legendFormat": "p95 {{job}}", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le, job) (rate(rpc_server_duration_milliseconds_bucket{job=~\"$service\"}[$rate_window])))", "legendFormat": "p99 {{job}}", "refId": "C"}
      ]
    },
    {
      "type": "table",
      "title": "Top gRPC methods by p99 latency",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 34},
      "id": 31,
      "options": {"showHeader": true, "footer": {"show": false, "reducer": ["sum"]}, "sortBy": [{"displayName": "Value", "desc": true}]},
      "fieldConfig": {
        "defaults": {"unit": "ms", "custom": {"align": "left", "displayMode": "color-text"}, "color": {"mode": "continuous-YlOrRd"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.hidden", "value": true}]}
        ]
      },
      "targets": [
        {"expr": "topk(10, histogram_quantile(0.99, sum by (le, job, rpc_service, rpc_method) (rate(rpc_server_duration_milliseconds_bucket{job=~\"$service\"}[$rate_window]))))", "format": "table", "instant": true, "refId": "A"}
      ],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"__name__": true, "Time": true}, "renameByName": {"Value": "p99 (ms)"}}}
      ]
    },
    {
      "type": "table",
      "title": "Top gRPC methods by error rate",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 34},
      "id": 32,
      "options": {"showHeader": true, "footer": {"show": false, "reducer": ["sum"]}, "sortBy": [{"displayName": "Value", "desc": true}]},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"align": "left", "displayMode": "color-text"}, "color": {"mode": "continuous-YlOrRd"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.hidden", "value": true}]}
        ]
      },
      "targets": [
        {"expr": "topk(10, sum by (job, rpc_service, rpc_method, rpc_grpc_status_code) (rate(rpc_server_duration_milliseconds_count{job=~\"$service\",rpc_grpc_status_code!=\"0\"}[$rate_window])))", "format": "table", "instant": true, "refId": "A"}
      ],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"__name__": true, "Time": true}, "renameByName": {"Value": "errors/s"}}}
      ]
    },

    {
      "type": "row",
      "title": "Runtime",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 43},
      "id": 104,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Memory (working set)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 44},
      "id": 40,
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"lineInterpolation": "smooth", "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull","max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"raf-banka\",container=~\"$service\"})", "legendFormat": "{{pod}}", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU usage",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 44},
      "id": 41,
      "fieldConfig": {"defaults": {"unit": "none", "decimals": 3, "custom": {"lineInterpolation": "smooth", "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull","max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"raf-banka\",container=~\"$service\"}[$rate_window]))", "legendFormat": "{{pod}}", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Goroutines",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 44},
      "id": 42,
      "fieldConfig": {"defaults": {"unit": "none", "custom": {"lineInterpolation": "smooth", "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull","max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "go_goroutines{job=~\"$service\"}", "legendFormat": "{{job}} {{pod}}", "refId": "A"}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Banka — Service RED",
  "uid": "banka-services-red",
  "version": 1,
  "weekStart": ""
}
